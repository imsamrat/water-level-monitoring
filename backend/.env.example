# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/water-level-db

# JWT Secret
JWT_SECRET=your_jwt_secret_key

# Email Configuration (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# API Key for ESP8266
API_KEY=esp8266_water_sensor_key_2024

# Server Port
PORT=5000

# Frontend URL (for CORS) — comma-separated for multiple origins
# Example: https://your-app.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173
